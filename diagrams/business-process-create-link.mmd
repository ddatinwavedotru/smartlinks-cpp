flowchart LR
    %% ============================================================================
    %% Бизнес-процесс: Создание SmartLink
    %% ============================================================================

    Start(["👤 Content<br/>Manager"])

    %% Preparation
    PrepareData["📝 Prepare<br/>Data"]
    DefineAlias["Define<br/>Alias"]
    WriteDSL["Write<br/>DSL Rules"]

    %% Validation
    ValidateDSL{"Validate<br/>DSL?"}
    Parser["🔍 DSL<br/>Parser"]
    CheckSyntax{"Syntax<br/>OK?"}

    %% MongoDB Insert
    InsertMongo["💾 Insert<br/>MongoDB"]
    Mongo[("💾 Mongo<br/>links")]
    CheckDuplicate{"Alias<br/>Exists?"}

    %% Results
    ResultSuccess["✅ Link<br/>Created"]
    ResultDuplicate["❌ Duplicate<br/>Alias"]
    ResultInvalidDSL["❌ Invalid<br/>DSL"]

    %% Test Link
    TestLink["🧪 Test<br/>Link"]
    GetRequest["GET<br/>/alias"]
    Result307["✅ 307<br/>Works"]

    End(["🎯 Done"])

    %% Main Flow
    Start --> PrepareData
    PrepareData --> DefineAlias
    PrepareData --> WriteDSL

    DefineAlias --> ValidateDSL
    WriteDSL --> ValidateDSL

    ValidateDSL --> Parser
    Parser --> CheckSyntax

    CheckSyntax -->|"Valid"| InsertMongo
    CheckSyntax -.->|"Invalid"| ResultInvalidDSL

    InsertMongo --> CheckDuplicate
    CheckDuplicate --> Mongo

    CheckDuplicate -->|"New"| Mongo
    CheckDuplicate -.->|"Exists"| ResultDuplicate

    Mongo --> ResultSuccess
    ResultSuccess --> TestLink

    TestLink --> GetRequest
    GetRequest --> Result307

    %% Error paths
    ResultInvalidDSL --> End
    ResultDuplicate --> End
    Result307 --> End

    %% Styling
    classDef startStyle fill:#e3f2fd,stroke:#1565c0,stroke-width:3px,font-size:16px
    classDef prepareStyle fill:#fff3e0,stroke:#e65100,stroke-width:2px,font-size:16px
    classDef validateStyle fill:#f3e5f5,stroke:#4a148c,stroke-width:2px,font-size:16px
    classDef dbStyle fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,font-size:16px
    classDef testStyle fill:#e1f5fe,stroke:#0277bd,stroke-width:2px,font-size:16px
    classDef successStyle fill:#c8e6c9,stroke:#388e3c,stroke-width:3px,font-size:16px
    classDef errorStyle fill:#ffcdd2,stroke:#d32f2f,stroke-width:2px,font-size:16px
    classDef endStyle fill:#e1f5fe,stroke:#0277bd,stroke-width:3px,font-size:16px

    class Start,End startStyle
    class PrepareData,DefineAlias,WriteDSL prepareStyle
    class ValidateDSL,Parser,CheckSyntax,CheckDuplicate validateStyle
    class InsertMongo,Mongo dbStyle
    class TestLink,GetRequest testStyle
    class ResultSuccess,Result307 successStyle
    class ResultDuplicate,ResultInvalidDSL errorStyle
